{
  "name": "turntable",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Standalone static JavaScript turntable app.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "smoke": "node scripts/smoke-check.js",
    "test:unit": "node --test tests/*.test.js tests/performance/*.test.js",
    "test:browser": "npm run build && playwright test",
    "test:audio": "node --test tests/audio-*.test.js tests/sampler-worklet.test.js",
    "test:smoke": "npm run smoke",
    "test": "npm run test:unit && npm run test:browser"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@fontsource/nunito": "^5.2.7"
  }
}
